# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it contains secrets.

# Access token for the web UI (any long random string)
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(32))"
APP_TOKEN=change-me-to-a-long-random-string

# Ollama Vision fallback — local AI, no API key needed (tried first if set)
# Point to your Ollama host; leave blank to disable
# From inside Docker use http://host.docker.internal:11434 (Mac/Win)
# or http://172.17.0.1:11434 (Linux host)
OLLAMA_URL=
OLLAMA_MODEL=llava

# Anthropic API key (for Claude Vision fallback hole detection)
# Tried only if Ollama is not set or returned nothing
# Leave blank to use OpenCV-only mode
ANTHROPIC_API_KEY=

# Claude model to use for vision (default: claude-opus-4-6)
CLAUDE_MODEL=claude-opus-4-6

# Set to "false" to disable Claude API calls entirely
USE_CLAUDE_FALLBACK=true
